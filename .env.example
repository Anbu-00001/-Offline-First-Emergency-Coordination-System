# OpenRescue Environment Variables Template
# Provide secure values for these variables in the .env file
# NOTE: Zero proprietary dependencies. Ensure NO fields for Google Maps, Firebase, etc. exist.

# PostgreSQL Configuration
POSTGRES_USER=openrescue
POSTGRES_PASSWORD=secure_password_here
POSTGRES_DB=openrescue_db

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Backend Configuration
ENVIRONMENT=development
LOG_LEVEL=info
SECRET_KEY=generate_a_secure_random_key_here

# Discovery Layer Configuration
SERVICE_NAME=openrescue_node
DISCOVERY_PORT=8000

# Tileserver Configuration (Day 10)
MBTILES_URL=
TILESERVER_PORT=8080

# OSRM Routing Configuration (Day 10)
OSM_PBF_URL=
OSRM_PORT=5000
