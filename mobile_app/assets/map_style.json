{
    "version": 8,
    "name": "OpenRescue Raster",
    "sources": {
        "base_tiles": {
            "type": "raster",
            "tiles": [
                "https://tile.openstreetmap.org/{z}/{x}/{y}.png"
            ],
            "tileSize": 256,
            "attribution": "© OpenStreetMap contributors"
        }
    },
    "layers": [
        {
            "id": "base_tiles_layer",
            "type": "raster",
            "source": "base_tiles",
            "minzoom": 0,
            "maxzoom": 19
        }
    ]
}